rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users — اقرأ وكتابة للمسجّلين
    match /users/{userId} {
      allow read:   if true;
      allow write:  if request.auth != null;
    }

    // Posts — اقرأ للكل، كتابة للمسجّلين
    match /posts/{postId} {
      allow read:   if true;
      allow write:  if request.auth != null;

      match /comments/{commentId} {
        allow read:  if true;
        allow write: if request.auth != null;
      }
    }

    // Leaderboard
    match /leaderboard/{weekId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
